{
    "compilerOptions": {
        "declaration": true,
        "target": "ES2020",
        "module": "commonjs",
        "jsx": "react",
        "outDir": "dist",
        "rootDir": ".",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true
    },
    "include": ["index.ts", "preload.ts"],
    "exclude": ["node_modules", "build", "dist"]
}

{
  "extends": [
    "plugin:react/recommended",
    "xo"
  ],

  "rules": {
    /* ─── базовые (оставляем) ─── */
    "indent": ["off", 4],
    "semi": ["error", "always"],

    /* ─── отключённые стилистические ─── */
    "array-bracket-spacing": "off",
    "arrow-parens": "off",
    "arrow-body-style": "off",          // ← не требует убирать фигурные скобки
    "capitalized-comments": "off",
    "object-curly-spacing": "off",
    "object-shorthand": "off",
    "padded-blocks": "off",
    "padding-line-between-statements": "off",
    "space-in-parens": "off",
    "unicorn/prefer-module": "off"
  },

  "settings": {
    "react": {
      "pragma": "React",
      "fragment": "Fragment",
      "version": "detect"
    }
  }
}
